# Docker self-hosted environment variables
# Copy this to .env before running docker-compose up
# Generate JWT_SECRET with: openssl rand -base64 48

# Required — no default, compose will refuse to start without this
JWT_SECRET=replace_with_a_long_random_secret_at_least_48_chars

# PostgreSQL (defaults match docker-compose.yml)
DB_HOST=db
DB_PORT=5432
DB_NAME=business_terminal
DB_USER=postgres
DB_PASSWORD=postgres

# Frontend origin for CORS (adjust if using a custom domain)
FRONTEND_URL=http://localhost:5173

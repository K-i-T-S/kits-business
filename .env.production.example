# Production Environment Variables
# Copy this file to .env.production and fill in the actual values

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application Configuration
VITE_APP_NAME=All-in-One Business Terminal
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=production

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Third-party Services
VITE_SENTRY_DSN=your-sentry-dsn-for-error-tracking
VITE_GOOGLE_ANALYTICS_ID=your-ga-measurement-id

# Security Configuration
VITE_CSP_NONCE_ENABLED=true
VITE_SECURITY_HEADERS_ENABLED=true

# API Configuration
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

# Cache Configuration
VITE_CACHE_TTL=3600000
VITE_ENABLE_OFFLINE_SUPPORT=true

# Monitoring and Observability
VITE_PERFORMANCE_BUDGET=500000
VITE_ENABLE_HEARTBEAT=true
VITE_HEARTBEAT_INTERVAL=30000

# Multi-tenant Configuration
VITE_ENABLE_MULTI_TENANCY=true
VITE_DEFAULT_TENANT=default

# Development/Debug (should be false in production)
VITE_DEBUG_MODE=false
VITE_ENABLE_CONSOLE_LOGS=false

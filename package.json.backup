    "test:all": "npm run test "test:all": "npm run test && npm run test:e2e && npm run test:visual""test:all": "npm run test && npm run test:e2e && npm run test:visual" npm run test:e2e "test:all": "npm run test && npm run test:e2e && npm run test:visual""test:all": "npm run test && npm run test:e2e && npm run test:visual" npm run test:visual",
    "test:visual:all": "npm run test:visual "test:all": "npm run test && npm run test:e2e && npm run test:visual""test:all": "npm run test && npm run test:e2e && npm run test:visual" npm run test:storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "verify": "npm run typecheck && npm run build"
  },

import { Badge } from './ui/badge'
import { Button } from './ui/button'
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from './ui/card'
import { Wifi, WifiOff, RefreshCw, AlertTriangle, Database } from 'lucide-react'
import { useOfflineSync } from '@/hooks/useOfflineSync'

export function OfflineIndicator() {
  const { syncStatus, syncActions } = useOfflineSync()

  if (syncStatus.isOnline && syncStatus.pendingActions === 0) {
    return null
  }

  return (
    <div className="fixed top-4 right-4 left-4 md:left-auto md:w-80 z-40">
      <Card className="bg-gray-900/95 backdrop-blur-md border-gray-700/50 shadow-2xl">
        <CardHeader className="pb-3">
          <div className="flex items-center gap-3">
            <div className={`p-2 rounded-lg ${
              syncStatus.isOnline ? 'bg-green-600/20' : 'bg-orange-600/20'
            }`}>
              {syncStatus.isOnline ? (
                <Wifi className="h-5 w-5 text-green-400" />
              ) : (
                <WifiOff className="h-5 w-5 text-orange-400" />
              )}
            </div>
            <div className="flex-1">
              <CardTitle className="text-sm font-medium text-white">
                {syncStatus.isOnline ? 'Syncing Pending' : 'Offline Mode'}
              </CardTitle>
              <CardDescription className="text-xs text-gray-400">
                {syncStatus.isOnline 
                  ? `${syncStatus.pendingActions} actions pending sync`
                  : 'Working offline. Changes will sync when connection is restored.'
                }
              </CardDescription>
            </div>
          </div>
        </CardHeader>
        
        {(syncStatus.isOnline && syncStatus.pendingActions > 0) && (
          <CardContent className="pt-0 space-y-3">
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-2">
                <Badge variant="secondary" className="text-xs bg-blue-600/20 text-blue-400 border-blue-600/30">
                  {syncStatus.pendingActions}
                </Badge>
                {syncStatus.isSyncing && (
                  <RefreshCw className="h-3 w-3 animate-spin text-blue-400" />
                )}
              </div>
              <Button
                onClick={syncActions}
                disabled={syncStatus.isSyncing}
                size="sm"
                variant="outline"
                className="border-gray-600 text-gray-300 hover:bg-gray-800 h-8"
              >
                {syncStatus.isSyncing ? 'Syncing...' : 'Sync Now'}
              </Button>
            </div>
          </CardContent>
        )}

        {!syncStatus.isOnline && (
          <CardContent className="pt-0 space-y-3">
            <div className="flex items-center gap-2 text-xs text-gray-400">
              <Database className="h-4 w-4" />
              <span>All changes are saved locally</span>
            </div>
            <div className="flex items-center gap-2 text-xs text-orange-400">
              <AlertTriangle className="h-4 w-4" />
              <span>Automatic sync will resume when connection is restored</span>
            </div>
          </CardContent>
        )}
      </Card>
    </div>
  )
}

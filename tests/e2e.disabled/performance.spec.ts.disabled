import { test, expect } from '@playwright/test';

test.describe('Performance Tests', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/');
  });

  test('page load performance', async ({ page }) => {
    const startTime = Date.now();
    await page.goto('/', { waitUntil: 'networkidle' });
    const loadTime = Date.now() - startTime;
    
    // Page should load within 3 seconds
    expect(loadTime).toBeLessThan(3000);
    
    // Check Core Web Vitals
    const metrics = await page.evaluate(() => {
      return new Promise((resolve) => {
        const observer = new PerformanceObserver((list) => {
          const entries = list.getEntries();
          const vitals = {};
          
          entries.forEach((entry) => {
            if (entry.entryType === 'navigation') {
              vitals.loadTime = entry.loadEventEnd - entry.loadEventStart;
              vitals.domContentLoaded = entry.domContentLoadedEventEnd - entry.domContentLoadedEventStart;
            }
          });
          
          resolve(vitals);
        });
        
        observer.observe({ entryTypes: ['navigation'] });
      });
    });
    
    expect(metrics.loadTime).toBeLessThan(1000);
  });

  test('largest contentful paint (LCP)', async ({ page }) => {
    const lcp = await page.evaluate(() => {
      return new Promise((resolve) => {
        const observer = new PerformanceObserver((list) => {
          const entries = list.getEntries();
          const lcpEntry = entries[entries.length - 1];
          resolve(lcpEntry.startTime);
        });
        
        observer.observe({ entryTypes: ['largest-contentful-paint'] });
      });
    });
    
    // LCP should be under 2.5 seconds
    expect(lcp).toBeLessThan(2500);
  });

  test('cumulative layout shift (CLS)', async ({ page }) => {
    const cls = await page.evaluate(() => {
      return new Promise((resolve) => {
        let clsValue = 0;
        const observer = new PerformanceObserver((list) => {
          const entries = list.getEntries();
          entries.forEach((entry) => {
            if (!entry.hadRecentInput) {
              clsValue += entry.value;
            }
          });
          resolve(clsValue);
        });
        
        observer.observe({ entryTypes: ['layout-shift'] });
        
        // Wait a bit for layout shifts to be recorded
        setTimeout(() => resolve(clsValue), 2000);
      });
    });
    
    // CLS should be under 0.1
    expect(cls).toBeLessThan(0.1);
  });

  test('first input delay (FID)', async ({ page }) => {
    await page.goto('/', { waitUntil: 'networkidle' });
    
    // Simulate user interaction
    const fid = await page.evaluate(() => {
      return new Promise((resolve) => {
        const observer = new PerformanceObserver((list) => {
          const entries = list.getEntries();
          if (entries.length > 0) {
            resolve(entries[0].processingStart - entries[0].startTime);
          }
        });
        
        observer.observe({ entryTypes: ['first-input'] });
        
        // Simulate a click to trigger FID
        document.body.click();
      });
    });
    
    // FID should be under 100ms
    expect(fid).toBeLessThan(100);
  });

  test('memory usage', async ({ page }) => {
    const memoryBefore = await page.evaluate(() => {
      return (performance as any).memory ? {
        used: (performance as any).memory.usedJSHeapSize,
        total: (performance as any).memory.totalJSHeapSize,
        limit: (performance as any).memory.jsHeapSizeLimit
      } : null;
    });
    
    // Perform some actions that might increase memory usage
    await page.click('body');
    await page.keyboard.press('Tab');
    await page.waitForTimeout(1000);
    
    const memoryAfter = await page.evaluate(() => {
      return (performance as any).memory ? {
        used: (performance as any).memory.usedJSHeapSize,
        total: (performance as any).memory.totalJSHeapSize,
        limit: (performance as any).memory.jsHeapSizeLimit
      } : null;
    });
    
    if (memoryBefore && memoryAfter) {
      const memoryIncrease = memoryAfter.used - memoryBefore.used;
      // Memory increase should be reasonable (less than 10MB)
      expect(memoryIncrease).toBeLessThan(10 * 1024 * 1024);
    }
  });

  test('bundle size and loading', async ({ page }) => {
    const resources = await page.evaluate(() => {
      return performance.getEntriesByType('resource').map((entry) => ({
        name: entry.name,
        size: (entry as any).transferSize || 0,
        duration: entry.duration,
        type: entry.name.includes('.js') ? 'script' : 
               entry.name.includes('.css') ? 'style' : 'other'
      }));
    });
    
    const jsResources = resources.filter(r => r.type === 'script');
    const cssResources = resources.filter(r => r.type === 'style');
    
    // Check total bundle sizes
    const totalJSSize = jsResources.reduce((sum, r) => sum + r.size, 0);
    const totalCSSSize = cssResources.reduce((sum, r) => sum + r.size, 0);
    
    // JavaScript bundle should be under 1MB (gzipped)
    expect(totalJSSize).toBeLessThan(1024 * 1024);
    
    // CSS should be under 100KB (gzipped)
    expect(totalCSSSize).toBeLessThan(100 * 1024);
  });

  test('rendering performance', async ({ page }) => {
    // Test frame rate during interactions
    await page.goto('/', { waitUntil: 'networkidle' });
    
    const frameRates = await page.evaluate(async () => {
      const frameRates = [];
      let lastTime = performance.now();
      
      const measureFrameRate = () => {
        const currentTime = performance.now();
        const frameRate = 1000 / (currentTime - lastTime);
        frameRates.push(frameRate);
        lastTime = currentTime;
      };
      
      // Measure for 2 seconds
      for (let i = 0; i < 120; i++) {
        measureFrameRate();
        await new Promise(resolve => setTimeout(resolve, 16.67)); // ~60fps
      }
      
      return frameRates;
    });
    
    const averageFrameRate = frameRates.reduce((sum, rate) => sum + rate, 0) / frameRates.length;
    
    // Should maintain at least 30fps on average
    expect(averageFrameRate).toBeGreaterThan(30);
  });

  test('network performance', async ({ page }) => {
    const networkMetrics = await page.evaluate(() => {
      return new Promise((resolve) => {
        const observer = new PerformanceObserver((list) => {
          const entries = list.getEntries();
          const metrics = {
            totalRequests: entries.length,
            totalSize: 0,
            slowRequests: 0,
            failedRequests: 0
          };
          
          entries.forEach((entry) => {
            const resource = entry as PerformanceResourceTiming;
            metrics.totalSize += resource.transferSize || 0;
            
            if (resource.duration > 1000) {
              metrics.slowRequests++;
            }
            
            if (resource.responseStatus >= 400) {
              metrics.failedRequests++;
            }
          });
          
          resolve(metrics);
        });
        
        observer.observe({ entryTypes: ['resource'] });
        
        // Wait for network activity to settle
        setTimeout(() => resolve({
          totalRequests: 0,
          totalSize: 0,
          slowRequests: 0,
          failedRequests: 0
        }), 3000);
      });
    });
    
    // Network performance checks
    expect((networkMetrics as any).failedRequests).toBe(0);
    expect((networkMetrics as any).slowRequests).toBeLessThan(3);
  });

  test('database query performance', async ({ page }) => {
    // Mock database operations and measure performance
    await page.addInitScript(() => {
      // Mock database query performance measurement
      (window as any).measureQueryPerformance = async () => {
        const start = performance.now();
        
        // Simulate database query
        await new Promise(resolve => setTimeout(resolve, 50));
        
        const end = performance.now();
        return end - start;
      };
    });
    
    const queryTimes = await page.evaluate(async () => {
      const times = [];
      for (let i = 0; i < 10; i++) {
        const time = await (window as any).measureQueryPerformance();
        times.push(time);
      }
      return times;
    });
    
    const averageQueryTime = queryTimes.reduce((sum, time) => sum + time, 0) / queryTimes.length;
    
    // Database queries should be under 100ms on average
    expect(averageQueryTime).toBeLessThan(100);
  });

  test('component rendering performance', async ({ page }) => {
    // Test component mount/unmount performance
    const componentMetrics = await page.evaluate(() => {
      return new Promise((resolve) => {
        const metrics = {
          mountTime: 0,
          unmountTime: 0,
          renderTime: 0
        };
        
        // Simulate component lifecycle
        const startMount = performance.now();
        
        // Simulate component mounting
        setTimeout(() => {
          metrics.mountTime = performance.now() - startMount;
          
          const startRender = performance.now();
          
          // Simulate rendering
          setTimeout(() => {
            metrics.renderTime = performance.now() - startRender;
            
            const startUnmount = performance.now();
            
            // Simulate unmounting
            setTimeout(() => {
              metrics.unmountTime = performance.now() - startUnmount;
              resolve(metrics);
            }, 10);
          }, 50);
        }, 10);
      });
    });
    
    // Component operations should be fast
    expect((componentMetrics as any).mountTime).toBeLessThan(50);
    expect((componentMetrics as any).renderTime).toBeLessThan(100);
    expect((componentMetrics as any).unmountTime).toBeLessThan(20);
  });

  test('scrolling performance', async ({ page }) => {
    await page.setViewportSize({ width: 1280, height: 720 });
    await page.goto('/', { waitUntil: 'networkidle' });
    
    // Measure scroll performance
    const scrollMetrics = await page.evaluate(async () => {
      const metrics = {
        frameDrops: 0,
        averageFrameTime: 0,
        maxFrameTime: 0
      };
      
      const frameTimes = [];
      let lastFrameTime = performance.now();
      
      const measureScroll = () => {
        const currentTime = performance.now();
        const frameTime = currentTime - lastFrameTime;
        frameTimes.push(frameTime);
        
        if (frameTime > 16.67) { // 60fps threshold
          metrics.frameDrops++;
        }
        
        metrics.maxFrameTime = Math.max(metrics.maxFrameTime, frameTime);
        lastFrameTime = currentTime;
      };
      
      // Simulate scrolling
      let scrollPosition = 0;
      const scrollInterval = setInterval(() => {
        window.scrollBy(0, 50);
        scrollPosition += 50;
        measureScroll();
        
        if (scrollPosition >= 1000) {
          clearInterval(scrollInterval);
          metrics.averageFrameTime = frameTimes.reduce((sum, time) => sum + time, 0) / frameTimes.length;
        }
      }, 16);
      
      return new Promise(resolve => {
        setTimeout(() => resolve(metrics), 2000);
      });
    });
    
    // Scrolling should be smooth
    expect((scrollMetrics as any).frameDrops).toBeLessThan(5);
    expect((scrollMetrics as any).averageFrameTime).toBeLessThan(20);
  });
});

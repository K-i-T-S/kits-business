import { test, expect } from '@playwright/test';

test.describe('Point of Sale E2E Tests', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('/');
  });

  test('POS interface loads and is functional', async ({ page }) => {
    // Look for POS-related navigation or buttons
    const posButton = page.locator('button:has-text("POS"), [data-testid="pos-button"], a:has-text("Point of Sale")');
    
    if (await posButton.isVisible()) {
      await posButton.click();
      
      // Check for POS interface elements
      const posInterface = page.locator('[data-testid="pos-interface"], .pos-interface');
      const productGrid = page.locator('[data-testid="product-grid"], .product-grid');
      const cart = page.locator('[data-testid="cart"], .cart');
      
      await expect(posInterface.or(productGrid).or(cart)).toBeVisible({ timeout: 5000 });
    }
  });

  test('product search and filtering works', async ({ page }) => {
    const posButton = page.locator('button:has-text("POS"), [data-testid="pos-button"]');
    
    if (await posButton.isVisible()) {
      await posButton.click();
      
      // Look for search functionality
      const searchInput = page.locator('input[placeholder*="search"], input[data-testid="product-search"]');
      
      if (await searchInput.isVisible()) {
        await searchInput.fill('test');
        await page.waitForTimeout(500);
        
        // Check that search results appear
        const searchResults = page.locator('[data-testid="search-results"], .product-item');
        const resultCount = await searchResults.count();
        
        // Should have some results or show no results message
        expect(resultCount > 0 || await page.locator(':has-text("No results")').isVisible()).toBeTruthy();
      }
    }
  });

  test('cart operations work correctly', async ({ page }) => {
    const posButton = page.locator('button:has-text("POS"), [data-testid="pos-button"]');
    
    if (await posButton.isVisible()) {
      await posButton.click();
      
      // Look for products to add to cart
      const products = page.locator('[data-testid="product-item"], .product-item, button:has-text("Add")');
      const productCount = await products.count();
      
      if (productCount > 0) {
        // Add first product to cart
        await products.first().click();
        
        // Check cart updates
        const cart = page.locator('[data-testid="cart"], .cart');
        const cartItems = page.locator('[data-testid="cart-item"], .cart-item');
        
        // Wait for cart to update
        await page.waitForTimeout(1000);
        
        // Verify cart has items or shows updated total
        const itemCount = await cartItems.count();
        expect(itemCount > 0 || await cart.locator(':has-text("$")').isVisible()).toBeTruthy();
      }
    }
  });

  test('payment process works', async ({ page }) => {
    const posButton = page.locator('button:has-text("POS"), [data-testid="pos-button"]');
    
    if (await posButton.isVisible()) {
      await posButton.click();
      
      // Add a product first
      const products = page.locator('[data-testid="product-item"], .product-item');
      const productCount = await products.count();
      
      if (productCount > 0) {
        await products.first().click();
        await page.waitForTimeout(1000);
        
        // Look for payment button
        const paymentButton = page.locator('button:has-text("Pay"), button:has-text("Checkout"), [data-testid="payment-button"]');
        
        if (await paymentButton.isVisible()) {
          await paymentButton.click();
          
          // Check for payment modal or interface
          const paymentModal = page.locator('[data-testid="payment-modal"], .payment-modal');
          const paymentOptions = page.locator('[data-testid="payment-options"], .payment-methods');
          
          await expect(paymentModal.or(paymentOptions)).toBeVisible({ timeout: 3000 });
        }
      }
    }
  });

  test('receipt generation works', async ({ page }) => {
    const posButton = page.locator('button:has-text("POS"), [data-testid="pos-button"]');
    
    if (await posButton.isVisible()) {
      await posButton.click();
      
      // Complete a simple transaction
      const products = page.locator('[data-testid="product-item"], .product-item');
      if (await products.count() > 0) {
        await products.first().click();
        await page.waitForTimeout(1000);
        
        // Look for receipt options
        const receiptButton = page.locator('button:has-text("Receipt"), button:has-text("Print"), [data-testid="receipt-button"]');
        
        if (await receiptButton.isVisible()) {
          await receiptButton.click();
          
          // Check for receipt preview or print options
          const receiptPreview = page.locator('[data-testid="receipt-preview"], .receipt');
          await expect(receiptPreview).toBeVisible({ timeout: 3000 });
        }
      }
    }
  });
});
